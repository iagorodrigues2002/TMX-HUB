# API
API_PORT=4000
API_HOST=0.0.0.0
LOG_LEVEL=info

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# S3-compatible storage (MinIO in dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=clones
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Render limits
MAX_RENDER_TIMEOUT_MS=90000
MAX_ASSET_BYTES=26214400
MAX_TOTAL_BYTES=262144000
BROWSER_POOL_SIZE=3

# Webhook signing (HMAC-SHA256). Replace before any non-dev deployment.
WEBHOOK_SECRET=dev-webhook-secret-change-me-in-production
PUBLIC_BASE_URL=http://localhost:4000

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
