# =============================================================================
# TMX HUB — Production env vars (Railway)
# =============================================================================
# These are what each Railway service expects. Copy the relevant block into the
# Variables tab of the corresponding service.
#
# Railway provides the following automatically — do NOT set them manually:
#   - PORT                         (the port the service must listen on)
#   - REDIS_URL                    (when you link the Redis plugin to the service)
#   - RAILWAY_PRIVATE_DOMAIN       (internal hostname for service-to-service)
#   - RAILWAY_PUBLIC_DOMAIN        (public HTTPS URL of the service)
# =============================================================================


# ---- Service: api  -----------------------------------------------------------
#
# Required:
LOG_LEVEL=info
WEBHOOK_SECRET=change-me-to-a-long-random-string
PUBLIC_BASE_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}

# Render limits (defaults are sane; override if needed):
MAX_RENDER_TIMEOUT_MS=90000
MAX_ASSET_BYTES=26214400
MAX_TOTAL_BYTES=262144000
BROWSER_POOL_SIZE=2

# Storage — Cloudflare R2 (recommended):
#   1. Create an R2 bucket at https://dash.cloudflare.com → R2
#   2. Create an API token (R2 Object Read + Write) for that bucket
#   3. Paste credentials below
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=tmx-hub-clones
S3_ACCESS_KEY=<r2-access-key-id>
S3_SECRET_KEY=<r2-secret-access-key>
S3_FORCE_PATH_STYLE=true

# Redis: linked via Railway plugin → REDIS_URL is injected automatically.
# (Don't set REDIS_URL manually unless using an external Redis.)


# ---- Service: web  -----------------------------------------------------------
#
# CRITICAL — set this to the api service's public URL.
# This value is baked into the client JavaScript bundle at BUILD TIME, so
# changing it requires a redeploy of the web service.
NEXT_PUBLIC_API_URL=https://<api-service-railway-public-domain>


# =============================================================================
# Local development (.env at the repo root, NOT committed)
# =============================================================================
# API_PORT=4000
# REDIS_URL=redis://localhost:6379
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=clones
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true
# WEBHOOK_SECRET=dev-webhook-secret
# PUBLIC_BASE_URL=http://localhost:4000
#
# packages/web/.env.local:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
