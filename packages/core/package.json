{
  "name": "@page-cloner/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@page-cloner/shared": "workspace:*",
    "archiver": "^7.0.1",
    "cheerio": "^1.0.0",
    "domhandler": "^5.0.3",
    "dompurify": "^3.2.2",
    "jsdom": "^25.0.1",
    "mime-types": "^2.1.35",
    "p-limit": "^6.1.0",
    "postcss": "^8.4.49",
    "postcss-value-parser": "^4.2.0",
    "ulid": "^2.3.0",
    "undici": "^7.0.0"
  },
  "peerDependencies": {
    "playwright": "^1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "peerDependenciesMeta": {
    "playwright": { "optional": true },
    "playwright-extra": { "optional": true },
    "puppeteer-extra-plugin-stealth": { "optional": true }
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.0",
    "playwright": "^1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.6"
  }
}
