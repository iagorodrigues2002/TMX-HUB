    "@fastify/swagger-ui": "^5.2.0",
    "@page-cloner/core": "workspace:*",
    "@page-cloner/shared": "workspace:*",
    "archiver": "^7.0.1",
    "bullmq": "^5.34.5",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0",
    "playwright": "^1.49.0",
